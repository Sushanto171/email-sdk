{
  "version": 3,
  "name": "email-sdk",
  "builds": [
    {
      "src": "src/sendEmail.ts",
      "use": "@vercel/node",
      "config": {
        "tsconfig": "tsconfig.json"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/src/sendEmail.ts"
    }
  ],
  "buildCommand": "npm run build",
  "outputDirectory": "dist"
}
