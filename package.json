{
  "name": "@sushantokumar/email-sdk",
  "version": "1.0.2",
  "description": "Minimal class-based, provider-agnostic email SDK with serverless API support",
  "main": "./dist/sendEmail.js",
  "module": "./dist/sendEmail.mjs",
  "types": "./dist/sendEmail.d.ts",
  "exports": {
    ".": {
      "require": "./dist/sendEmail.js",
      "import": "./dist/sendEmail.mjs",
      "types": "./dist/sendEmail.d.ts"
    }
  },
  "files": [
    "dist/sendEmail.js",
    "dist/sendEmail.mjs",
    "dist/sendEmail.d.ts",
    "dist/sendEmail.d.mts",
    "dist/types.d.ts",
    "dist/types.js"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sushanto171/email-sdk.git"
  },
  "homepage": "https://github.com/Sushanto171/email-sdk#readme",
  "bugs": {
    "url": "https://github.com/Sushanto171/email-sdk/issues"
  },
  "scripts": {
    "build": "tsup src/sendEmail.ts --format cjs,esm --dts",
    "build:server": "tsup src/server.ts --format cjs --no-dts --out-dir dist/server",
    "start": "node dist/server/server.js",
    "dev": "tsx src/server.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "email",
    "sdk",
    "smtp",
    "serverless"
  ],
  "author": "Sushanto Kumar",
  "license": "MIT",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^7.0.11",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "nodemailer": "^8.0.2",
    "tsup": "^7.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.5"
  }
}
